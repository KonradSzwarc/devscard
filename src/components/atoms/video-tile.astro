---
import Typography from '@/atoms/typography.astro';
import type { Video } from '@/types/favorites-section';

export interface Props {
  value: Video;
}

const {
  value: { title, url },
} = Astro.props;

const id = url.split('/').pop();
const thumbnail = `https://img.youtube.com/vi/${id}/0.jpg`;
---

<a href={url} class="flex w-full flex-col gap-3 transition duration-300 hover:translate-y-2">
  <img class="aspect-video rounded-lg object-cover shadow-md" src={thumbnail} alt={title} />
  <Typography variant="tile-title">
    {title}
  </Typography>
</a>
