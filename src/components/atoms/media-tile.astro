---
import Typography from '@/atoms/typography.astro';
import type { Media } from '@/types/favorites-section';

export interface Props {
  value: Media;
}

const {
  value: { image, title, type, url },
} = Astro.props;
---

<a href={url} class="flex w-full flex-col gap-3 transition duration-300 hover:translate-y-2">
  <img class="aspect-square rounded-lg object-cover shadow-md" src={image} alt={title} />
  <div class="gap-1">
    <Typography variant="tile-title">
      {title}
    </Typography>
    <Typography variant="tile-subtitle">
      {type}
    </Typography>
  </div>
</a>
